# LLM Provider Configuration
# Choose between 'litellm' or 'openrouter'
LLM_PROVIDER=openrouter

# OpenRouter API Configuration (required for both providers)
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model Configuration (used by both providers)
MODEL_ID=openrouter/minimax/minimax-m2.5

# Vault Configuration
# Path to your Obsidian vault root (the directory containing Bookmarks/ and Meta/)
VAULT_PATH=
